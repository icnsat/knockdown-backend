{
    "builds": [
        {
            "src": "knockdown/knockdown/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.14" 
            }
        },
        {
            "src": "build_files.sh",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.14"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "knockdown/knockdown/wsgi.py"
        }
    ]
}